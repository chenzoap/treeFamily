rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función para verificar si el usuario es el dueño del árbol
    // Usamos getAfter para casos de creación o verificamos el documento existente
    function isTreeOwner(treeId) {
      return request.auth != null && 
             get(/databases/$(database)/documents/trees/$(treeId)).data.ownerId == request.auth.uid;
    }

    // Reglas para la colección de Árboles
    match /trees/{treeId} {
      // Solo el dueño puede leer su árbol
      allow read: if request.auth != null && resource.data.ownerId == request.auth.uid;
      
      // Bloqueamos escritura directa al documento del árbol (solo vía Admin/Functions)
      allow write: if false;

      // Reglas para subcolecciones (Persons y Relationships)
      match /persons/{personId} {
        allow read: if isTreeOwner(treeId);
        // CAMBIO: Permitir escribir si eres el dueño del árbol
        allow write: if isTreeOwner(treeId); 
      }

      match /relationships/{relId} {
        allow read: if isTreeOwner(treeId);
        // CAMBIO: Permitir escribir si eres el dueño del árbol
        allow write: if isTreeOwner(treeId);
      }
    }
  }
}